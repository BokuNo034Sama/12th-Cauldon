# Shared
NODE_ENV=development

# Public web configuration
NEXT_PUBLIC_APP_NAME="12th Cauldron"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API and database values are added in later prompt-pack steps.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/12th_cauldron?schema=public"
JWT_SECRET="replace-with-at-least-32-characters"
OTP_SECRET="replace-with-at-least-32-characters"

# Notifications
SMS_PROVIDER="mock"
SMS_SENDER_ID="12Cauldron"
SMS_CHANNEL="generic"
TERMII_BASE_URL="https://api.ng.termii.com"
TERMII_API_KEY="replace-with-termii-api-key"
